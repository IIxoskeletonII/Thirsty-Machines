# Data — raw downloads excluded by size, processed excluded to
# force regeneration from notebooks
data/raw/**/*.csv
data/raw/**/*.xlsx
data/raw/**/*.gpkg
data/raw/**/*.json
data/processed/**/*.csv
data/processed/**/*.parquet

# But keep provenance files and the .gitkeep markers
!data/raw/**/PROVENANCE.md
!data/**/.gitkeep
!data/**/README.md

