        <style>
          <style-rule element='axis'>
            <encoding attr='space' class='0' field='[federated.1mldx7i07vmxij1gyr8ly1a4xbu1].[avg:Mean Combined Energy (Wh):qk]' field-type='quantitative' scale='log' scope='cols' type='space' />
