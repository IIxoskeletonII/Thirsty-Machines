      <aliases enabled='yes' />
      <column caption='Pillar' datatype='string' name='[Calculation_0882151731748864]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [metric]&#13;&#10;  WHEN &quot;energy_MWh&quot;     THEN &quot;Energy&quot;&#13;&#10;  WHEN &quot;households_MWh&quot; THEN &quot;Energy&quot;&#13;&#10;  WHEN &quot;water_kL&quot;       THEN &quot;Water&quot;&#13;&#10;  WHEN &quot;pools_kL&quot;       THEN &quot;Water&quot;&#13;&#10;  WHEN &quot;carbon_tCO2e&quot;   THEN &quot;Carbon&quot;&#13;&#10;  WHEN &quot;flights_tCO2e&quot;  THEN &quot;Carbon&quot;&#13;&#10;END' />
      </column>
      <column caption='Is raw metric' datatype='boolean' name='[Calculation_0882151731818497]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[metric] = &quot;energy_MWh&quot; &#13;&#10;  OR [metric] = &quot;water_kL&quot; &#13;&#10;  OR [metric] = &quot;carbon_tCO2e&quot;' />
      </column>
      <column caption='Equivalence value' datatype='real' name='[Calculation_0882151731912706]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [metric]&#13;&#10;  WHEN &quot;energy_MWh&quot; THEN &#13;&#10;    { FIXED [Model], [scale] : &#13;&#10;        MAX(IF [metric] = &quot;households_MWh&quot; THEN [value] END) }&#13;&#10;  WHEN &quot;water_kL&quot; THEN &#13;&#10;    { FIXED [Model], [scale] : &#13;&#10;        MAX(IF [metric] = &quot;pools_kL&quot; THEN [value] END) }&#13;&#10;  WHEN &quot;carbon_tCO2e&quot; THEN &#13;&#10;    { FIXED [Model], [scale] : &#13;&#10;        MAX(IF [metric] = &quot;flights_tCO2e&quot; THEN [value] END) }&#13;&#10;END' />
      </column>
      <column caption='Equivalence label' datatype='string' name='[Calculation_0882151732011011]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [metric]&#13;&#10;  WHEN &quot;energy_MWh&quot;   THEN &quot;MWh of U.S. household energy&quot;&#13;&#10;  WHEN &quot;water_kL&quot;     THEN &quot;Olympic swimming pools&quot;&#13;&#10;  WHEN &quot;carbon_tCO2e&quot; THEN &quot;transatlantic flights&quot;&#13;&#10;END' />
      </column>
      <column caption='Raw unit label' datatype='string' name='[Calculation_0882151732064260]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [metric]&#13;&#10;  WHEN &quot;energy_MWh&quot;   THEN &quot;MWh&quot;&#13;&#10;  WHEN &quot;water_kL&quot;     THEN &quot;kL&quot;&#13;&#10;  WHEN &quot;carbon_tCO2e&quot; THEN &quot;tCO₂e&quot;&#13;&#10;END' />
      </column>
